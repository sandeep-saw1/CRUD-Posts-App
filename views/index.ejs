<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Mini Social</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Mini Social</h1>

<% for(let post of posts){ %>

<div class="post">
    <h3>@<%= post.username %></h3>

    <p><%= post.content %></p>

    <a href="/posts/<%= post.id %>" class="DetailBT">See In Detail</a>
    <a href="/posts/<%= post.id %>/edit" class="EditBT">Edit</a>
    <a href="/posts/<%= post.id %>/delete" class="DeleteBT">Delete</a>
</div>

<% } %>

<br>

<a href="/posts/new" class="CreateBT">Create New Post</a>

</body>
</html>