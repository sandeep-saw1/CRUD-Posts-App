<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Create Post</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h2>Create New Post</h2>

<form action="/posts" method="POST">

    <input
        type="text"
        name="username"
        placeholder="Enter username"
        required
    >

    <br><br>

    <textarea
        name="content"
        placeholder="Write something..."
        rows="5"
        cols="30"
        required
    ></textarea>

    <br><br>

    <button type="submit" class="EditBT">Create Post</button>

</form>

</body>
</html>